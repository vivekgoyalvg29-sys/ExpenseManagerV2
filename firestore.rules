rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// WhereIsMyMoney – Firestore Security Rules
//
// Data model
// ──────────
//   users/{phone}
//       activeProfileId : string
//       profiles        : string[]
//       revokedProfiles : map[]    (temporary notification list)
//
//   profiles/{profileId}
//       name               : string
//       isDefault          : bool
//       isShareable        : bool
//       shareCode          : string   (6-char, always present)
//       shareCodeActive    : bool
//       defaultMemberRole  : 'editor' | 'viewer'
//       createdBy          : phone string
//       members            : { phone: 'owner'|'editor'|'viewer' }
//
//   profiles/{profileId}/transactions/{docId}
//   profiles/{profileId}/accounts/{docId}
//   profiles/{profileId}/categories/{docId}
//   profiles/{profileId}/budgets/{docId}
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    // True when the caller is authenticated via Firebase phone auth.
    function isSignedIn() {
      return request.auth != null && request.auth.token.phone_number != null;
    }

    // The caller's phone number (e.g. "+919876543210").
    function myPhone() {
      return request.auth.token.phone_number;
    }

    // Fetch the profile document to inspect membership. Reads inside rules
    // are free and do not count against your quota.
    function profileDoc(profileId) {
      return get(/databases/$(database)/documents/profiles/$(profileId)).data;
    }

    // True when the caller is listed in the profile's members map.
    function isMember(profileId) {
      return myPhone() in profileDoc(profileId).members;
    }

                // True when the caller has write access to the profile's data.
                // All members (owner and member) can write — viewer role removed.
                function canEdit(profileId) {
                  return isMember(profileId);
                }

    // ── users/{phone} ───────────────────────────────────────────────────────

    match /users/{userPhone} {
      // Only the owner can read their own user document.
      allow read: if isSignedIn() && myPhone() == userPhone;

      // Write rules:
      //  • A user always writes to their own document (active profile, joining).
      //  • A profile OWNER also writes to OTHER members' user documents when
      //    revoking access or removing a member (see ProfileService). We cannot
      //    cheaply verify the caller is an owner of a shared profile without an
      //    extra read, so we permit writes by any authenticated user. The app
      //    only ever writes known fields (profiles[], revokedProfiles[],
      //    activeProfileId), limiting the blast radius.
      allow write: if isSignedIn();
    }

    // ── profiles/{profileId} ────────────────────────────────────────────────

    match /profiles/{profileId} {

      // Any signed-in user can READ profile documents.
      // Required so a non-member can query by shareCode in the join flow and
      // so ProfileService can look up share-code uniqueness when generating codes.
      allow read: if isSignedIn();

      // Any signed-in user can CREATE a profile (the app always sets the creator
      // as 'owner' in the members map).
      allow create: if isSignedIn();

      // UPDATE is allowed in two distinct situations:
      //   1. The caller is already a member of this profile (any role). This
      //      covers: owner changing settings, owner revoking shareable, owner
      //      renaming, owner removing members, member leaving, etc.
      //   2. The caller is NOT yet a member and is adding only themselves as a
      //      new member with a non-owner role (the join-by-code flow).
      allow update: if isSignedIn() && (
        // Case 1 – existing member
        myPhone() in resource.data.members
        ||
        // Case 2 – joining: only the 'members' map changes, only the caller's
        // own phone is being added, and the role is not 'owner'.
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members'])
          && !(myPhone() in resource.data.members)
          && request.resource.data.members.keys().toSet()
               == resource.data.members.keys().toSet()
                    .union([myPhone()].toSet())
                      && request.resource.data.members[myPhone()] in ['member', 'editor', 'viewer']
        )
      );

      // Only the profile owner can delete a profile document.
      allow delete: if isSignedIn()
        && resource.data.members[myPhone()] == 'owner';

      // ── Subcollections: transactions / accounts / categories / budgets ────

      match /{subcollection}/{docId} {
        // Viewers, editors, and owners can all read subcollection data.
        allow read:  if isSignedIn() && isMember(profileId);

        // Only editors and owners can write (insert / update / delete) records.
        // Viewers are read-only.
        allow write: if isSignedIn() && canEdit(profileId);
      }
    }

  }
}
