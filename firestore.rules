rules_version = '2';
// Target database: krchabookdb
// Apply these rules in Firebase Console → Firestore → Rules (select krchabookdb database)

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    // Phone number stored in the JWT by Firebase Phone Auth
    function myPhone() {
      return request.auth.token.phone_number;
    }

    // Any authenticated user whose phone appears in the profile's members map
    function isMember(profileId) {
      return isAuthed() &&
        get(/databases/$(database)/documents/profiles/$(profileId))
          .data.members[myPhone()] != null;
    }

    // Only the owner may delete/restructure the profile itself
    function isOwner(profileId) {
      return isAuthed() &&
        get(/databases/$(database)/documents/profiles/$(profileId))
          .data.members[myPhone()] == 'owner';
    }

    // ── Profiles ─────────────────────────────────────────────────────────────

    match /profiles/{profileId} {
      // Any member can read the profile document (needed for share-code display etc.)
      allow read: if isMember(profileId);
      // Any authenticated user can create a profile (owner sets themselves as member)
      allow create: if isAuthed();
      // Any member can update the profile document (rename, toggle shareable, etc.)
      allow update: if isMember(profileId);
      // Only the owner can delete the profile
      allow delete: if isOwner(profileId);

      // ── Sub-collections (categories, accounts, transactions, budgets) ──────
      match /{collection}/{docId} {
        allow read:  if isMember(profileId);
        allow write: if isMember(profileId);
      }
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Each user document is keyed by phone number; only that user may access it.
    match /users/{phone} {
      allow read, write: if isAuthed() && myPhone() == phone;
    }
  }
}
