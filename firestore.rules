rules_version = '2';
// Target database: krchabookdb
// Apply these rules in Firebase Console → Firestore → Rules (select krchabookdb database)

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    // Phone number stored in the JWT by Firebase Phone Auth
    function myPhone() {
      return request.auth.token.phone_number;
    }

    // Checks membership using resource.data (the document already in hand).
    // Use this for rules on the profile document itself to avoid a circular
    // get() call (i.e. fetching the same doc the rule is evaluating).
    function isMemberByData() {
      return isAuthed() && resource.data.members[myPhone()] != null;
    }

    function isOwnerByData() {
      return isAuthed() && resource.data.members[myPhone()] == 'owner';
    }

    // Checks membership via a get() on the parent profile document.
    // Safe to use only from sub-collection rules (where profileId is the
    // parent, not the current document — so no circular reference).
    function isMember(profileId) {
      return isAuthed() &&
        get(/databases/$(database)/documents/profiles/$(profileId))
          .data.members[myPhone()] != null;
    }

    function isOwner(profileId) {
      return isAuthed() &&
        get(/databases/$(database)/documents/profiles/$(profileId))
          .data.members[myPhone()] == 'owner';
    }

    // ── Profiles ─────────────────────────────────────────────────────────────

    match /profiles/{profileId} {
      // Any authenticated user can read profile documents.
      // This is intentionally permissive so that:
      //   • getMyProfiles() list queries work without circular get() errors
      //   • joinProfileByCode() can look up profiles by shareCode before joining
      //   • _generateShareCode() can check uniqueness across all profiles
      allow read: if isAuthed();

      // Any authenticated user can create a profile (they add themselves as owner)
      allow create: if isAuthed();

      // Members can update. Also allow the original creator to update when
      // members[phone] is missing/corrupt (e.g. legacy keys or account
      // recreated) so merge/self-heal in ensureDefaultProfileExists can run.
      allow update: if isMemberByData() ||
        (isAuthed() && resource.data.createdBy == myPhone());

      // Only the owner can delete (uses resource.data — no circular get())
      allow delete: if isOwnerByData();

      // ── Sub-collections (categories, accounts, transactions, budgets) ──────
      // Financial data is strictly member-only. The get() here fetches the
      // parent profile document, which is a different doc — not circular.
      match /{collection}/{docId} {
        allow read:  if isMember(profileId);
        allow write: if isMember(profileId);
      }
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Each user document is keyed by phone number; only that user may access it.
    match /users/{phone} {
      allow read, write: if isAuthed() && myPhone() == phone;
    }
  }
}
