<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="3dp"
    android:paddingTop="4dp"
    android:paddingEnd="3dp"
    android:paddingBottom="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_card_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="5dp"
        android:orientation="vertical"
        android:paddingStart="3dp"
        android:paddingTop="8dp"
        android:paddingEnd="3dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:gravity="top"
            android:minHeight="48dp"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingEnd="8dp"
            android:paddingBottom="2dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="0dp"
                android:layout_marginTop="-2dp"
                android:background="@drawable/widget_calendar_bg">

                <TextView
                    android:id="@+id/widget_calendar_day"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/widget_calendar_day_inner"
                    android:gravity="center"
                    android:minWidth="28dp"
                    android:minHeight="24dp"
                    android:paddingHorizontal="3dp"
                    android:paddingVertical="1dp"
                    android:text="5"
                    android:textColor="#FF374151"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/widget_period"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="center_horizontal"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="April-26"
                        android:textColor="#FF111111"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/widget_pace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top"
                        android:layout_marginStart="4dp"
                        android:maxLines="1"
                        android:text="↑ High"
                        android:textColor="#FF16A34A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <View
                        android:id="@+id/widget_trailing_balance"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_expense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="none"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="₹0"
                    android:textColor="#FFDC2626"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="4dp"
            android:indeterminate="false"
            android:max="1000"
            android:maxHeight="7dp"
            android:minHeight="7dp"
            android:progress="0"
            android:progressDrawable="@drawable/widget_expense_progress" />
    </LinearLayout>
</FrameLayout>
